# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf

# C++ source files - must use spaces to match clang-format UseTab: Never
[*.{cpp,hpp,h,cc,cxx,c,inl}]
indent_style = space
indent_size = 4
tab_width = 4

# CMake files - consistent with C++ settings
[{CMakeLists.txt,*.cmake}]
indent_style = space
indent_size = 4
end_of_line = lf

# Script files - consistent with C++ settings
[*.{sh,bash}]
indent_style = space
indent_size = 4
end_of_line = lf

[*.bat]
indent_style = tab
indent_size = 4
end_of_line = crlf

# Configuration files
[*.{json,yml,yaml}]
indent_style = space
indent_size = 2
end_of_line = lf

# Markdown documentation
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
end_of_line = lf

# Makefiles always use tabs
[{Makefile,*.mk}]
indent_style = tab
