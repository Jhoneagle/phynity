# Set default behavior to automatically normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files and force LF
*.cpp text eol=lf
*.hpp text eol=lf
*.h text eol=lf
*.c text eol=lf
*.cc text eol=lf
*.cxx text eol=lf
*.cmake text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
CMakeLists.txt text eol=lf
.clang-format text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Denote binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.a binary
*.lib binary
*.o binary
*.obj binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
